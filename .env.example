# MCP Foundry — Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit the .env file to version control.

# Exchange selection
MCP_EXCHANGE=bybit

# Exchange API credentials
EXCHANGE_API_KEY=your_api_key_here
EXCHANGE_API_SECRET=your_api_secret_here

# Use testnet? (true/false) — always start with testnet
EXCHANGE_TESTNET=true

# Account category: "linear" for USDT perps, "spot" for spot
EXCHANGE_CATEGORY=linear

# MCP Server settings
MCP_SERVER_HOST=0.0.0.0
MCP_SERVER_PORT=8000

# Optional: API key to protect the MCP server itself
# MCP_SERVER_API_KEY=your_server_api_key

# Logging
LOG_LEVEL=INFO
